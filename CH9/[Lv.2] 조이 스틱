def solution(name):
    up_down_move = 0
    for char in name:
        up_down_move += min(ord(char) - ord('A'), ord('Z') - ord(char) + 1)
        
    n = len(name)
    min_left_right = n - 1
    
    for i in range(n):
        next_idx = i + 1
        while next_idx < n and name[next_idx] == 'A':
            next_idx += 1
            
        path1 = i + i + (n - next_idx) 
        path2 = (n - next_idx) + (n - next_idx) + i
        min_left_right = min(min_left_right, path1, path2)
        
    return up_down_move + min_left_right
