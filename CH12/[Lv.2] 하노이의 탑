def solution(n):
    answer = []
    
    def hanoi(count, start, end, mid):
        if count == 1:
            answer.append([start, end])
            return
            
        hanoi(count - 1, start, mid, end)
        answer.append([start, end])
        hanoi(count - 1, mid, end, start)

    hanoi(n, 1, 3, 2)
    
    return answer
