def solution(m, n, puddles):
    # dp 초기화
    dp = [[0] * (m + 1) for _ in range(n + 1)]
    
    # 시작점 설정
    dp[1][1] = 1
    
    # 웅덩이 위치 설정
    # [열, 행] → [행, 열]로 변경
    puddles_set = {(q, p) for [p, q] in puddles}
    
    for i in range(1, n + 1):
        for j in range(1, m + 1):
            
            # 시작점인 경우 → 패스
            if i == 1 and j == 1:
                continue
                
            # 웅덩이인 경우 → 패스
            if (i, j) in puddles_set:
                dp[i][j] = 0
                continue
            
            # 위에서 오는 경우 + 왼쪽에서 오는 경우
            dp[i][j] = (dp[i - 1][j] + dp[i][j - 1]) % 1000000007
    
    # 결과 반환
    return dp[n][m]
